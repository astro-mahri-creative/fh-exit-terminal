# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/exit-terminal?retryWrites=true&w=majority

# Server Port
PORT=5000

# Email Service (Gmail SMTP via App Password)
# 1. Enable 2FA on the Google account
# 2. Go to Google Account → Security → App Passwords → generate one for "Mail"
# 3. Paste the 16-char app password below (no spaces)
GMAIL_USER=you@yourdomain.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx
